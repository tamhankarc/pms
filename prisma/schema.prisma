generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  REPORT_VIEWER
  ACCOUNTS
}

enum FunctionalRoleCode {
  DEVELOPER
  QA
  DESIGNER
  LOCALIZATION
  DEVOPS
  PROJECT_MANAGER
  OTHER
  BILLING
}

enum BillingModel {
  HOURLY
  FIXED_FULL
  FIXED_MONTHLY
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum EstimateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISED
}

enum BillingTransactionType {
  PARTIAL_BILLING
  UPGRADE_PRE_COMPLETION
  UPGRADE_POST_COMPLETION
  ADJUSTMENT
}

model User {
  id                     String              @id @default(cuid())
  fullName               String
  username               String              @unique
  email                  String              @unique
  passwordHash           String
  userType               UserType
  functionalRole         FunctionalRoleCode?
  employeeCode           String?             @unique
  designation            String?
  joiningDate            DateTime?
  phoneNumber            String?
  isActive               Boolean             @default(true)
  currentAddress         String?             @db.Text
  permanentAddress       String?             @db.Text
  permanentSameAsCurrent Boolean             @default(false)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  createdProjects Project[] @relation("ProjectCreatedBy")
  updatedProjects Project[] @relation("ProjectUpdatedBy")

  projectAssignments    ProjectUserAssignment[]
  subProjectAssignments SubProjectAssignment[]

  managedEmployees           EmployeeTeamLead[] @relation("TeamLeadAssignments")
  employeeSupervisors        EmployeeTeamLead[] @relation("EmployeeAssignments")
  teamLeadAssignmentsCreated EmployeeTeamLead[] @relation("EmployeeTeamLeadAssignedBy")

  estimates       Estimate[]
  estimateReviews EstimateReview[] @relation("EstimateReviewer")

  timeEntries      TimeEntry[]
  timeEntryReviews TimeEntryReview[] @relation("TimeEntryReviewer")

  @@index([userType, isActive])
  @@index([functionalRole, isActive])
}

model Client {
  id                         String   @id @default(cuid())
  name                       String
  code                       String?  @unique
  isActive                   Boolean  @default(true)
  showCountriesInTimeEntries Boolean  @default(false)
  showMoviesInEntries        Boolean  @default(false)
  showLanguagesInEntries     Boolean  @default(false)
  enableProjectTypes         Boolean  @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  movies       Movie[]
  projects     Project[]
  projectTypes ProjectType[]

  @@index([isActive])
}

model ProjectType {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  projects Project[]

  @@unique([clientId, name])
  @@index([clientId, isActive])
}

model Movie {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  code        String?  @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  estimates   Estimate[]
  timeEntries TimeEntry[]

  @@index([clientId, isActive])
  @@index([title])
}

model Language {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates   Estimate[]
  timeEntries TimeEntry[]

  @@index([isActive])
  @@index([name])
}

model Country {
  id        String   @id @default(cuid())
  name      String
  isoCode   String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimates   Estimate[]
  timeEntries TimeEntry[]

  @@index([isActive])
  @@index([name])
}

model Project {
  id                 String        @id @default(cuid())
  clientId           String
  projectTypeId      String?
  code               String?       @unique
  name               String
  description        String?       @db.Text
  billingModel       BillingModel
  status             ProjectStatus @default(DRAFT)
  fixedContractHours Decimal?      @db.Decimal(10, 2)
  fixedMonthlyHours  Decimal?      @db.Decimal(10, 2)
  startDate          DateTime?
  endDate            DateTime?
  isActive           Boolean       @default(true)
  createdById        String?
  updatedById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  hideCountriesInEntries Boolean   @default(false)

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projectType ProjectType? @relation(fields: [projectTypeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy   User?        @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy   User?        @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  subProjects         SubProject[]
  assignedUsers       ProjectUserAssignment[]
  estimates           Estimate[]
  timeEntries         TimeEntry[]
  billingTransactions BillingTransaction[]

  @@index([clientId, isActive])
  @@index([projectTypeId])
  @@index([status])
  @@index([billingModel])
  @@index([createdById])
  @@index([updatedById])
}

model SubProject {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hideCountriesInEntries Boolean @default(false)

  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  assignments SubProjectAssignment[]
  estimates   Estimate[]
  timeEntries TimeEntry[]

  @@unique([projectId, name])
  @@index([projectId, isActive])
}

model ProjectUserAssignment {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  assignedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model SubProjectAssignment {
  id           String   @id @default(cuid())
  subProjectId String
  userId       String
  assignedAt   DateTime @default(now())

  subProject SubProject @relation(fields: [subProjectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([subProjectId, userId])
  @@index([userId])
}

model EmployeeTeamLead {
  id           String   @id @default(cuid())
  employeeId   String
  teamLeadId   String
  assignedById String?
  assignedAt   DateTime @default(now())

  employee   User  @relation("EmployeeAssignments", fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamLead   User  @relation("TeamLeadAssignments", fields: [teamLeadId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  assignedBy User? @relation("EmployeeTeamLeadAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([employeeId, teamLeadId])
  @@index([teamLeadId])
  @@index([assignedById])
}

model Estimate {
  id               String         @id @default(cuid())
  projectId        String
  subProjectId     String?
  employeeId       String
  countryId        String?
  movieId          String?
  languageId       String?
  workDate         DateTime
  estimatedMinutes Int
  notes            String?        @db.Text
  status           EstimateStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  subProject SubProject?      @relation(fields: [subProjectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  employee   User             @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  country    Country?         @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  movie      Movie?           @relation(fields: [movieId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  language   Language?        @relation(fields: [languageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reviews    EstimateReview[]

  @@index([projectId, workDate])
  @@index([subProjectId])
  @@index([employeeId, workDate])
  @@index([status])
  @@index([countryId])
  @@index([movieId])
  @@index([languageId])
}

model EstimateReview {
  id             String         @id @default(cuid())
  estimateId     String
  reviewerId     String
  decisionStatus EstimateStatus
  remarks        String?        @db.Text
  reviewedAt     DateTime       @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewer User     @relation("EstimateReviewer", fields: [reviewerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([estimateId, reviewedAt])
  @@index([reviewerId])
}

model TimeEntry {
  id           String          @id @default(cuid())
  projectId    String
  subProjectId String?
  employeeId   String
  countryId    String?
  movieId      String?
  languageId   String?
  workDate     DateTime
  taskName     String
  minutesSpent Int
  isBillable   Boolean         @default(true)
  notes        String?         @db.Text
  status       TimeEntryStatus @default(DRAFT)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  subProject SubProject?       @relation(fields: [subProjectId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  employee   User              @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  country    Country?          @relation(fields: [countryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  movie      Movie?            @relation(fields: [movieId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  language   Language?         @relation(fields: [languageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reviews    TimeEntryReview[]

  @@index([projectId, workDate])
  @@index([subProjectId])
  @@index([employeeId, workDate])
  @@index([status])
  @@index([countryId])
  @@index([movieId])
  @@index([languageId])
}

model TimeEntryReview {
  id             String          @id @default(cuid())
  timeEntryId    String
  reviewerId     String
  decisionStatus TimeEntryStatus
  remarks        String?         @db.Text
  reviewedAt     DateTime        @default(now())

  timeEntry TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reviewer  User      @relation("TimeEntryReviewer", fields: [reviewerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([timeEntryId, reviewedAt])
  @@index([reviewerId])
}


model AuditLog {
  id          String   @id @default(uuid()) @db.Char(36)
  actorId     String?
  entityType  String
  entityId    String?
  actionType  String
  description String?  @db.Text
  beforeJson  String?  @db.LongText
  afterJson   String?  @db.LongText
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model BillingTransaction {
  id              String                 @id @default(cuid())
  projectId       String
  transactionType BillingTransactionType
  amountMoney     Decimal?               @db.Decimal(12, 2)
  amountHours     Decimal?               @db.Decimal(10, 2)
  description     String?                @db.Text
  effectiveDate   DateTime
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([projectId, effectiveDate])
  @@index([transactionType])
}
